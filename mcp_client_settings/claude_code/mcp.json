{
  "mcpServers": {
    "1c-server-direct": {
      "type": "http",
      "url": "http://localhost/your_base_name/hs/mcp/"
    },
    "1c-server-http": {
      "type": "http",
      "url": "http://localhost:8000/mcp/"
    },
    "1c-server-stdio": {
      "command": "d:/rep/1c_mcp/venv/Scripts/python.exe",
      "args": ["-m", "src.py_server"],
      "cwd": "D:/rep/1c_mcp",
      "env": {
        "PYTHONPATH": "D:/rep/1c_mcp",
        "PYTHONIOENCODING": "utf-8",
        "MCP_ONEC_URL": "http://localhost/your_base_name",
        "MCP_ONEC_USERNAME": "<пользователь 1С>",
        "MCP_ONEC_PASSWORD": "<пароль пользователя 1С>",
        "MCP_ONEC_SERVICE_ROOT": "mcp",
        "MCP_SERVER_NAME": "1C-Metadata",
        "MCP_SERVER_VERSION": "1.0.0"
      }
    }
  }
}
